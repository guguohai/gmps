# --- Global Configuration ---
DEBUG=True
TZ=Asia/Shanghai

# --- Docker Compose / Infra ---
MYSQL_VERSION=8.0
MYSQL_HOST=mysql
MYSQL_PORT=3307
MYSQL_CONTAINER_PORT=3306
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=ps_admin
MYSQL_USER=ps_user
MYSQL_PASSWORD=change_me

REDIS_VERSION=7
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONTAINER_PORT=6379

CORE_API_PORT=8000
NOTIFICATION_SERVICE_PORT=8001
ADMIN_WEB_PORT=4173

# Database (Local Host mapping. Docker services will override via docker-compose)
DATABASE_URL=mysql://root:change_me@127.0.0.1:3307/ps_admin

# Celery / Redis (Local Host mapping. Docker services will override via docker-compose)
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# JWT Auth
SECRET_KEY=replace_with_real_secret
JWT_SECRET_KEY=replace_with_real_secret
JWT_ALGORITHM=HS256

# Notification Service
SERVICE_NAME=notification_service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001

# Mini Program
MINIAPP_NOTIFY_URL=http://localhost:3000/api/mock/notify
MINIAPP_NOTIFY_SECRET=your_secret_key_here
